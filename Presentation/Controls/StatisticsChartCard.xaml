<UserControl
    x:Class="KeyboardAnalysis.Presentation.Controls.StatisticsChartCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI">
    <local:DashboardCard x:Name="Root" xmlns:local="using:KeyboardAnalysis.Presentation.Controls" Title="{x:Bind Title, Mode=OneWay}" Subtitle="{x:Bind Subtitle, Mode=OneWay}">
        <local:DashboardCard.CardContent>
            <lvc:CartesianChart Height="260" Series="{x:Bind Series, Mode=OneWay}" XAxes="{x:Bind XAxes, Mode=OneWay}" YAxes="{x:Bind YAxes, Mode=OneWay}" LegendPosition="{x:Bind LegendPosition, Mode=OneWay}" TooltipPosition="{x:Bind TooltipPosition, Mode=OneWay}" />
        </local:DashboardCard.CardContent>
    </local:DashboardCard>
</UserControl>
