<UserControl
    x:Class="KeyboardAnalysis.Presentation.Controls.FilterBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:KeyboardAnalysis.Presentation.Models">
    <Border Style="{StaticResource CardBorderStyle}" Padding="20" Margin="0,0,0,24">
        <StackPanel Spacing="12">
            <TextBlock Text="Filters" FontWeight="SemiBold" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <StackPanel><TextBlock Text="Time interval" Style="{StaticResource CaptionTextBlockStyle}" /><ComboBox ItemsSource="{x:Bind ViewModel.TimeIntervals}" SelectedItem="{x:Bind ViewModel.SelectedTimeInterval, Mode=TwoWay}" Style="{StaticResource FilterComboBoxStyle}" /></StackPanel>
                <StackPanel><TextBlock Text="Aggregate by" Style="{StaticResource CaptionTextBlockStyle}" /><ComboBox ItemsSource="{x:Bind ViewModel.Aggregations}" SelectedItem="{x:Bind ViewModel.SelectedAggregation, Mode=TwoWay}" Style="{StaticResource FilterComboBoxStyle}" /></StackPanel>
                <StackPanel>
                    <TextBlock Text="Keys" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Button Content="Select keys" MinWidth="150" HorizontalAlignment="Left">
                        <Button.Flyout><Flyout Placement="Bottom"><StackPanel Width="240" Spacing="10"><TextBox PlaceholderText="Search keys" /><ListView ItemsSource="{x:Bind ViewModel.KeyOptions}" SelectionMode="Multiple" SelectionChanged="OnMultiSelectChanged" MaxHeight="220"><ListView.ItemTemplate><DataTemplate x:DataType="models:SelectableOption"><TextBlock Text="{x:Bind Name}" /></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Flyout></Button.Flyout>
                    </Button>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Programs" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Button Content="Select programs" MinWidth="160" HorizontalAlignment="Left">
                        <Button.Flyout><Flyout Placement="Bottom"><StackPanel Width="240" Spacing="10"><TextBox PlaceholderText="Search programs" /><ListView ItemsSource="{x:Bind ViewModel.ProgramOptions}" SelectionMode="Multiple" SelectionChanged="OnMultiSelectChanged" MaxHeight="220"><ListView.ItemTemplate><DataTemplate x:DataType="models:SelectableOption"><TextBlock Text="{x:Bind Name}" /></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Flyout></Button.Flyout>
                    </Button>
                </StackPanel>
                <Button Content="Reset filters" Command="{x:Bind ViewModel.ResetFiltersCommand}" Style="{StaticResource ResetButtonStyle}" VerticalAlignment="Bottom" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
