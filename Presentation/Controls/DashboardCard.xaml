<UserControl
    x:Class="KeyboardAnalysis.Presentation.Controls.DashboardCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Style="{StaticResource CardBorderStyle}">
        <Grid RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="{x:Bind Title, Mode=OneWay}" Style="{StaticResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" Style="{StaticResource DashboardSubtitleTextStyle}" />
            </StackPanel>
            <ContentPresenter Grid.Row="1" Content="{x:Bind CardContent, Mode=OneWay}" />
        </Grid>
    </Border>
</UserControl>
